rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Check if the current user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the current user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Check if the user is the owner of the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ---------------------------------------------------------
    // Products & Categories
    // ---------------------------------------------------------
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // Orders
    // ---------------------------------------------------------
    match /orders/{orderId} {
      // Admins can read all. Users can only read their own orders.
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      
      // Users can create orders for themselves
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Only admins can update or delete orders freely. 
      // Users can only update their own order to cancel it (modifying ONLY the status field).
      allow update: if isAdmin() || (
        isAuthenticated() && 
        resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
        request.resource.data.status == 'cancelled'
      );
      
      // Orders should rarely be deleted in production, keep it admin only
      allow delete: if isAdmin();
    }
    
    // ---------------------------------------------------------
    // Users
    // ---------------------------------------------------------
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create/update their profile, but cannot give themselves admin privileges
      allow create: if isOwner(userId) && (!request.resource.data.keys().hasAny(['role']) || request.resource.data.role == 'user');
      
      // Prevent role escalation during updates
      allow update: if isAdmin() || (isOwner(userId) && (
        !request.resource.data.keys().hasAny(['role']) || 
        request.resource.data.role == resource.data.role
      ));
      
      allow delete: if isAdmin() || isOwner(userId);
    }

    // ---------------------------------------------------------
    // Carts
    // ---------------------------------------------------------
    match /carts/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // ---------------------------------------------------------
    // Store Settings
    // ---------------------------------------------------------
    match /settings/{document=**} {
      allow read: if true; // Store info needs to be readable by the frontend
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // Fallback: Deny everything else
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
